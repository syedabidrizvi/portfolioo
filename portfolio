          <div class="stat-label">Design Tools</div>
        </div>
        <div class="stat">
          <div class="stat-num">79%</div>
          <div class="stat-label">Intermediate Score</div>
        </div>
        <div class="stat">
          <div class="stat-num">🥇</div>
