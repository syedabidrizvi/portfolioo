<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Mohd Abid Raza — Creative Portfolio</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Syne:wght@400;600;700;800&family=DM+Mono:ital,wght@0,400;1,400&display=swap" rel="stylesheet">
<style>
  :root {
    --black: #0a0a0a;
    --gold: #f5a623;
    --gold-dark: #c4821a;
    --white: #f0ede8;
    --grey: #1a1a1a;
    --mid: #2a2a2a;
    --text-dim: #888;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html { scroll-behavior: smooth; }

  body {
    background: var(--black);
    color: var(--white);
    font-family: 'Syne', sans-serif;
    overflow-x: hidden;
    cursor: none;
  }

  /* Custom cursor */
  .cursor {
    width: 12px; height: 12px;
    background: var(--gold);
    border-radius: 50%;
    position: fixed; top: 0; left: 0;
    pointer-events: none; z-index: 9999;
    transition: transform 0.1s;
    mix-blend-mode: difference;
  }
  .cursor-ring {
    width: 36px; height: 36px;
    border: 1.5px solid var(--gold);
    border-radius: 50%;
    position: fixed; top: 0; left: 0;
    pointer-events: none; z-index: 9998;
    transition: all 0.15s ease;
    opacity: 0.5;
  }

  /* Nav */
  nav {
    position: fixed; top: 0; left: 0; right: 0;
    z-index: 100;
    display: flex; align-items: center; justify-content: space-between;
    padding: 1.4rem 3rem;
    background: rgba(10,10,10,0.85);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid #1f1f1f;
  }
  .nav-logo {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1.4rem;
    letter-spacing: 0.12em;
    color: var(--gold);
  }
  .nav-links { display: flex; gap: 2.5rem; list-style: none; }
  .nav-links a {
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--text-dim);
    text-decoration: none;
    transition: color 0.2s;
    position: relative;
  }
  .nav-links a::after {
    content: '';
    position: absolute; bottom: -4px; left: 0;
    width: 0; height: 1px;
    background: var(--gold);
    transition: width 0.3s;
  }
  .nav-links a:hover { color: var(--white); }
  .nav-links a:hover::after { width: 100%; }

  /* Hero */
  #hero {
    min-height: 100vh;
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    padding: 8rem 3rem 4rem;
    position: relative;
    overflow: hidden;
  }
  .hero-bg {
    position: absolute; inset: 0;
    background:
      radial-gradient(ellipse 60% 60% at 80% 50%, rgba(245,166,35,0.07) 0%, transparent 70%),
      radial-gradient(ellipse 40% 40% at 20% 80%, rgba(245,166,35,0.04) 0%, transparent 60%);
  }
  .hero-grid-lines {
    position: absolute; inset: 0; opacity: 0.04;
    background-image:
      linear-gradient(var(--white) 1px, transparent 1px),
      linear-gradient(90deg, var(--white) 1px, transparent 1px);
    background-size: 60px 60px;
  }

  .hero-left { position: relative; z-index: 1; }
  .hero-tag {
    display: inline-flex; align-items: center; gap: 0.5rem;
    background: rgba(245,166,35,0.1);
    border: 1px solid rgba(245,166,35,0.3);
    padding: 0.35rem 0.9rem;
    border-radius: 100px;
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 1.5rem;
    animation: fadeUp 0.8s ease both;
  }
  .hero-tag::before {
    content: ''; width: 6px; height: 6px;
    background: var(--gold);
    border-radius: 50%;
    animation: pulse 2s infinite;
  }
  @keyframes pulse {
    0%,100% { opacity: 1; }
    50% { opacity: 0.3; }
  }
  .hero-name {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(4rem, 8vw, 7rem);
    line-height: 0.95;
    letter-spacing: 0.02em;
    animation: fadeUp 0.8s 0.1s ease both;
  }
  .hero-name span { color: var(--gold); }
  .hero-subtitle {
    font-size: 0.9rem;
    color: var(--text-dim);
    margin-top: 1.5rem;
    max-width: 440px;
    line-height: 1.8;
    animation: fadeUp 0.8s 0.2s ease both;
  }
  .hero-cta {
    display: flex; gap: 1rem; margin-top: 2.5rem;
    animation: fadeUp 0.8s 0.3s ease both;
  }
  .btn-primary {
    background: var(--gold);
    color: var(--black);
    font-family: 'Syne', sans-serif;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    padding: 0.9rem 2rem;
    border: none; border-radius: 4px;
    text-decoration: none;
    transition: background 0.2s, transform 0.2s;
    display: inline-block;
  }
  .btn-primary:hover { background: var(--gold-dark); transform: translateY(-2px); }
  .btn-outline {
    background: transparent;
    color: var(--white);
    font-family: 'Syne', sans-serif;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    padding: 0.9rem 2rem;
    border: 1px solid #333; border-radius: 4px;
    text-decoration: none;
    transition: border-color 0.2s, transform 0.2s;
    display: inline-block;
  }
  .btn-outline:hover { border-color: var(--gold); transform: translateY(-2px); }

  .hero-right {
    position: relative; z-index: 1;
    display: flex; justify-content: flex-end; align-items: center;
  }
  .hero-card {
    background: var(--grey);
    border: 1px solid #222;
    border-radius: 16px;
    padding: 2rem;
    width: 320px;
    animation: fadeUp 0.8s 0.4s ease both;
  }
  .hero-card-photo {
    width: 80px; height: 80px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--gold), #a06800);
    display: flex; align-items: center; justify-content: center;
    font-family: 'Bebas Neue', sans-serif;
    font-size: 2rem; color: var(--black);
    margin-bottom: 1rem;
  }
  .hero-card h3 { font-size: 1rem; font-weight: 700; margin-bottom: 0.3rem; }
  .hero-card p { font-size: 0.75rem; color: var(--text-dim); margin-bottom: 1.2rem; }
  .hero-stats {
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 0.8rem;
  }
  .stat {
    background: var(--mid);
    border-radius: 8px;
    padding: 0.8rem;
  }
  .stat-num {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1.6rem; color: var(--gold);
    line-height: 1;
  }
  .stat-label { font-size: 0.65rem; color: var(--text-dim); margin-top: 0.2rem; }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* Marquee strip */
  .marquee-strip {
    background: var(--gold);
    padding: 0.8rem 0;
    overflow: hidden;
    white-space: nowrap;
  }
  .marquee-inner {
    display: inline-flex; gap: 3rem;
    animation: marquee 20s linear infinite;
  }
  .marquee-inner span {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1rem; letter-spacing: 0.1em;
    color: var(--black);
  }
  .marquee-inner .dot { color: rgba(0,0,0,0.4); }
  @keyframes marquee {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }

  /* Sections */
  section { padding: 6rem 3rem; }
  .section-label {
    font-size: 0.7rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 0.8rem;
    font-family: 'DM Mono', monospace;
  }
  .section-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(2.5rem, 5vw, 4rem);
    line-height: 1;
    margin-bottom: 3rem;
  }

  /* About */
  #about { border-top: 1px solid #1a1a1a; }
  .about-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: start; }
  .about-text p {
    font-size: 1rem; line-height: 1.8; color: #aaa;
    margin-bottom: 1.2rem;
  }
  .about-text p strong { color: var(--white); }
  .about-highlights { display: flex; flex-direction: column; gap: 1rem; }
  .highlight-item {
    display: flex; align-items: flex-start; gap: 1rem;
    background: var(--grey);
    border: 1px solid #1f1f1f;
    border-radius: 10px;
    padding: 1.2rem 1.4rem;
    transition: border-color 0.2s;
  }
  .highlight-item:hover { border-color: var(--gold); }
  .highlight-icon {
    width: 40px; height: 40px; flex-shrink: 0;
    background: rgba(245,166,35,0.12);
    border-radius: 8px;
    display: flex; align-items: center; justify-content: center;
    font-size: 1.1rem;
  }
  .highlight-item h4 { font-size: 0.85rem; font-weight: 700; margin-bottom: 0.2rem; }
  .highlight-item p { font-size: 0.75rem; color: var(--text-dim); line-height: 1.5; }

  /* Skills */
  #skills { background: var(--grey); }
  .skills-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1rem; }
  .skill-card {
    background: var(--black);
    border: 1px solid #1f1f1f;
    border-radius: 10px;
    padding: 1.5rem;
    transition: border-color 0.2s, transform 0.2s;
    position: relative; overflow: hidden;
  }
  .skill-card::before {
    content: '';
    position: absolute; top: 0; left: 0; right: 0;
    height: 2px;
    background: var(--gold);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.3s;
  }
  .skill-card:hover { border-color: #333; transform: translateY(-4px); }
  .skill-card:hover::before { transform: scaleX(1); }
  .skill-icon { font-size: 1.8rem; margin-bottom: 0.8rem; }
  .skill-card h3 { font-size: 0.9rem; font-weight: 700; margin-bottom: 0.4rem; }
  .skill-card p { font-size: 0.72rem; color: var(--text-dim); line-height: 1.6; }

  /* Software */
  .software-list { display: flex; flex-wrap: wrap; gap: 0.8rem; margin-top: 2rem; }
  .software-tag {
    background: var(--mid);
    border: 1px solid #333;
    border-radius: 6px;
    padding: 0.5rem 1.1rem;
    font-size: 0.8rem;
    font-family: 'DM Mono', monospace;
    color: var(--white);
    transition: border-color 0.2s, color 0.2s;
  }
  .software-tag:hover { border-color: var(--gold); color: var(--gold); }

  /* Experience */
  #experience { border-top: 1px solid #1a1a1a; }
  .exp-items { display: flex; flex-direction: column; gap: 1.5rem; }
  .exp-item {
    display: grid; grid-template-columns: 120px 1fr;
    gap: 2rem;
    background: var(--grey);
    border: 1px solid #1f1f1f;
    border-radius: 12px;
    padding: 1.8rem;
    transition: border-color 0.2s;
  }
  .exp-item:hover { border-color: rgba(245,166,35,0.3); }
  .exp-year {
    font-family: 'DM Mono', monospace;
    font-size: 0.75rem; color: var(--gold);
    padding-top: 0.2rem;
  }
  .exp-content h3 { font-size: 1rem; font-weight: 700; margin-bottom: 0.4rem; }
  .exp-content .role {
    font-size: 0.75rem; color: var(--gold);
    font-family: 'DM Mono', monospace;
    margin-bottom: 0.7rem;
  }
  .exp-content p { font-size: 0.82rem; color: #888; line-height: 1.7; }

  /* Education */
  #education { background: var(--grey); }
  .edu-timeline { position: relative; padding-left: 2rem; }
  .edu-timeline::before {
    content: '';
    position: absolute; left: 0; top: 10px; bottom: 10px;
    width: 1px; background: #2a2a2a;
  }
  .edu-item {
    position: relative; margin-bottom: 2.5rem;
    padding-left: 2rem;
  }
  .edu-item::before {
    content: '';
    position: absolute; left: -2.4rem; top: 8px;
    width: 10px; height: 10px;
    background: var(--gold);
    border-radius: 50%;
    box-shadow: 0 0 0 3px rgba(245,166,35,0.2);
  }
  .edu-year {
    font-family: 'DM Mono', monospace;
    font-size: 0.7rem; color: var(--gold);
    margin-bottom: 0.4rem;
  }
  .edu-item h3 { font-size: 1rem; font-weight: 700; margin-bottom: 0.3rem; }
  .edu-item p { font-size: 0.8rem; color: var(--text-dim); }

  /* Certificate */
  .cert-card {
    background: var(--black);
    border: 1px solid #222;
    border-radius: 16px;
    padding: 2rem;
    display: flex; align-items: center; gap: 2rem;
    margin-top: 3rem;
    max-width: 600px;
    transition: border-color 0.2s;
  }
  .cert-card:hover { border-color: var(--gold); }
  .cert-icon {
    width: 60px; height: 60px; flex-shrink: 0;
    background: rgba(245,166,35,0.1);
    border: 1px solid rgba(245,166,35,0.3);
    border-radius: 12px;
    display: flex; align-items: center; justify-content: center;
    font-size: 1.8rem;
  }
  .cert-card h3 { font-size: 0.95rem; font-weight: 700; margin-bottom: 0.3rem; }
  .cert-card p { font-size: 0.75rem; color: var(--text-dim); }
  .cert-card .cert-id {
    font-family: 'DM Mono', monospace;
    font-size: 0.65rem; color: var(--gold);
    margin-top: 0.4rem;
  }

  /* Achievement */
  #achievements { border-top: 1px solid #1a1a1a; }
  .achievement-card {
    background: linear-gradient(135deg, rgba(245,166,35,0.08), rgba(245,166,35,0.02));
    border: 1px solid rgba(245,166,35,0.25);
    border-radius: 16px;
    padding: 2.5rem;
    max-width: 700px;
    position: relative; overflow: hidden;
  }
  .achievement-card::after {
    content: '🥇';
    position: absolute; right: 2rem; top: 50%;
    transform: translateY(-50%);
    font-size: 4rem; opacity: 0.15;
  }
  .achievement-card h3 { font-size: 1.1rem; font-weight: 700; margin-bottom: 0.6rem; }
  .achievement-card p { font-size: 0.85rem; color: var(--text-dim); line-height: 1.7; }
  .achievement-badge {
    display: inline-block;
    background: var(--gold);
    color: var(--black);
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    padding: 0.3rem 0.8rem;
    border-radius: 4px;
    margin-bottom: 1rem;
  }

  /* Contact */
  #contact { background: var(--grey); }
  .contact-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 3rem; align-items: start; }
  .contact-info { display: flex; flex-direction: column; gap: 1rem; }
  .contact-item {
    display: flex; align-items: center; gap: 1rem;
    background: var(--black);
    border: 1px solid #1f1f1f;
    border-radius: 10px; padding: 1.2rem 1.4rem;
    text-decoration: none; color: var(--white);
    transition: border-color 0.2s;
  }
  .contact-item:hover { border-color: var(--gold); }
  .contact-item-icon {
    width: 38px; height: 38px;
    background: rgba(245,166,35,0.1);
    border-radius: 8px;
    display: flex; align-items: center; justify-content: center;
    font-size: 1rem; flex-shrink: 0;
  }
  .contact-item-label { font-size: 0.65rem; color: var(--text-dim); letter-spacing: 0.1em; text-transform: uppercase; }
  .contact-item-value { font-size: 0.85rem; font-weight: 600; margin-top: 0.1rem; }
  .contact-right h3 {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 2.5rem; line-height: 1.1; margin-bottom: 1rem;
  }
  .contact-right p { font-size: 0.85rem; color: var(--text-dim); line-height: 1.7; }

  /* Footer */
  footer {
    border-top: 1px solid #1a1a1a;
    padding: 2rem 3rem;
    display: flex; align-items: center; justify-content: space-between;
  }
  .footer-logo {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1.2rem; color: var(--gold); letter-spacing: 0.1em;
  }
  footer p { font-size: 0.72rem; color: var(--text-dim); }

  /* Scroll animations */
  .reveal {
    opacity: 0; transform: translateY(30px);
    transition: opacity 0.7s ease, transform 0.7s ease;
  }
  .reveal.visible { opacity: 1; transform: translateY(0); }

  @media (max-width: 768px) {
    nav { padding: 1rem 1.5rem; }
    .nav-links { gap: 1.5rem; }
    #hero { grid-template-columns: 1fr; padding: 7rem 1.5rem 3rem; }
    .hero-right { display: none; }
    section { padding: 4rem 1.5rem; }
    .about-grid, .contact-grid { grid-template-columns: 1fr; }
    .exp-item { grid-template-columns: 1fr; gap: 0.5rem; }
    footer { flex-direction: column; gap: 0.5rem; text-align: center; }
  }
</style>
</head>
<body>

<div class="cursor" id="cursor"></div>
<div class="cursor-ring" id="cursorRing"></div>

<nav>
  <div class="nav-logo">MAR</div>
  <ul class="nav-links">
    <li><a href="#about">About</a></li>
    <li><a href="#skills">Skills</a></li>
    <li><a href="#experience">Work</a></li>
    <li><a href="#education">Education</a></li>
